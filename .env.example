# Self-host runtime
# Copy this file to `.env` before starting the stack.
# For the default self-host setup, only PostgreSQL, Redis, and AUTH_SHARED_SECRET
# need to be configured when external auth is used. Leave other variables at
# their defaults unless you need the related optional feature.
POSTGRES_USER=ermis
POSTGRES_PASSWORD=ermis
POSTGRES_DB=ermis_end_user
DATABASE_URL=postgres://ermis:ermis@postgres:5432/ermis_end_user
REDIS_URL=redis://redis:6379

# HS256 auth shared by user-service, chat-service, stream-service, and trusted backends
# NOTE: This value must be identical to `jwt_secret` in `config/bellboy.toml`.
AUTH_SHARED_SECRET=replace-with-strong-shared-auth-secret
ACCESS_TOKEN_TTL_SECONDS=900
SERVICE_TOKEN_TTL_SECONDS=300
REFRESH_TOKEN_TTL_SECONDS=2592000

# User cache and API limits
USER_CACHE_ENABLED=false
USER_PROFILE_CACHE_TTL_SECONDS=60
USER_SERVICES_CACHE_TTL_SECONDS=300
BATCH_USERS_LIMIT=100

# Login providers
OTP_ENABLED=true
OTP_SECRET=replace-with-otp-secret
OTP_DEBUG=false
OTP_TTL_SECONDS=300
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
GOOGLE_CLIENT_IDS=replace-google-client-id-1,replace-google-client-id-2
APPLE_CLIENT_IDS=replace-apple-client-id


# Optional OTP delivery providers
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRANDNAME=BeloChat.vn
ESMS_SANDBOX=false
STRINGEE_API_SID_KEY=
STRINGEE_API_SECRET_KEY=
STRINGEE_FROM_NUMBER=842873000295
STRINGEE_FROM_ALIAS=BELOCHAT
STRINGEE_ANSWER_URL=
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
OTP_EMAIL_FROM=Ermis <system@example.com>

# Optional S3-compatible avatar storage.
# Configure this only when the end-user service needs to update user avatars
# without sharing the main service storage.
S3_ENABLED=false
AWS_BUCKET_NAME=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT=
AWS_PUBLIC_URL=
AWS_BUCKET_PATH=avatars
